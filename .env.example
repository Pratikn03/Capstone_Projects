# ORIUS environment variables (copy to .env and fill in as needed)

# Tokens / credentials for optional data sources
ELECTRICITYMAPS_TOKEN=
WATTTIME_USERNAME=
WATTTIME_PASSWORD=

# Optional alerting webhook (Slack/MS Teams or generic HTTP endpoint)
ORIUS_ALERT_WEBHOOK=

# Logging
ORIUS_LOG_LEVEL=INFO
ORIUS_LOG_FORMAT=text   # text | json

# API readiness paths (override if you store data elsewhere)
ORIUS_FEATURES_PATH=data/processed/features.parquet
ORIUS_MODELS_DIR=artifacts/models

# Frontend (Next.js)
OPENAI_API_KEY=
FASTAPI_URL=http://localhost:8000

