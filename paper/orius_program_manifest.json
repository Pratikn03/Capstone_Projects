{
  "manifest_version": "2.0.0",
  "created_at_utc": "2026-04-02T00:00:00Z",
  "purpose": "ORIUS three-domain submission monograph manifest",
  "canonical_manuscript": "orius_book.tex",
  "canonical_review_dossier": "paper/review/orius_review_dossier.tex",
  "canonical_outputs": [
    "paper/paper.pdf",
    "paper.pdf",
    "paper/review/orius_review_dossier.pdf"
  ],
  "canonical_review_build": "make review-compile",
  "canonical_architecture": {
    "package_root": "src/orius/",
    "official_backbone": [
      "src/orius/adapters/",
      "src/orius/universal_theory/",
      "src/orius/dc3s/",
      "src/orius/certos/",
      "src/orius/orius_bench/",
      "src/orius/multi_agent/",
      "services/api/routers/research.py",
      "frontend/src/app/api/data/route.ts",
      "frontend/src/app/api/reports/route.ts"
    ],
    "canonical_import_rule": {
      "adapters": "orius.adapters.*",
      "universal_theory": "orius.universal_theory.*",
      "safety_logic": "orius.dc3s.*",
      "runtime_os": "orius.certos.*",
      "benchmark": "orius.orius_bench.*",
      "multi_agent": "orius.multi_agent.*"
    },
    "legacy_compatibility_paths": [
      "src/orius/domain/",
      "src/orius/universal_framework/",
      "src/orius/vehicles/"
    ]
  },
  "monograph_posture": {
    "book_level_claim": "ORIUS provides a reliability-aware runtime safety layer for physical AI under degraded observation, enforcing certificate-backed action release through uncertainty coverage, repair, and fallback.",
    "active_program_shape": "three_domain_only",
    "witness_row": "battery",
    "defended_bounded_rows": [
      "autonomous_vehicles",
      "healthcare"
    ]
  },
  "governed_truth_surfaces": {
    "metrics_manifest": "paper/metrics_manifest.json",
    "claim_matrix": "paper/claim_matrix.csv",
    "claim_validator": "scripts/validate_paper_claims.py",
    "monograph_generator": "scripts/build_orius_monograph_assets.py",
    "domain_closure_matrix": "reports/publication/orius_domain_closure_matrix.csv",
    "universal_claim_matrix": "reports/publication/orius_universal_claim_matrix.csv",
    "chapter_map": "reports/publication/orius_monograph_chapter_map.csv"
  },
  "active_build_commands": [
    "PYTHONPATH=src .venv/bin/python scripts/build_orius_monograph_assets.py",
    "PYTHONPATH=src .venv/bin/python scripts/validate_paper_claims.py",
    "make orius-book",
    "make review-compile",
    "make publish-audit"
  ],
  "archive_policy": {
    "legacy_program_surfaces": "archive_only_or_rewritten_as_noncanonical_pointers",
    "frozen_package_bundles": "historical_noncanonical",
    "active_monograph_surfaces": [
      "orius_book.tex",
      "paper/",
      "paper/monograph/",
      "paper/review/",
      "reports/publication/",
      "reports/legacy_archive/README.md"
    ]
  }
}
