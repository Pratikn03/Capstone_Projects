[Unit]
Description=ORIUS API
After=network.target

[Service]
Type=simple
User=orius
WorkingDirectory=/opt/orius
EnvironmentFile=/etc/orius/orius.env
ExecStart=/opt/orius/.venv/bin/uvicorn services.api.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
