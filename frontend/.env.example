# ORIUS Dashboard Environment Variables

# LLM Provider
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# FastAPI Backend
FASTAPI_URL=http://localhost:8000
FASTAPI_TIMEOUT_MS=12000

# API Authentication
API_SECRET_KEY=orius-api-secret

# Optional dashboard protection for production.
# Format is "username:password"; browsers will show a Basic Auth prompt.
DASHBOARD_BASIC_AUTH=operator:change-me

# Public UI labels. These are bundled into the client; do not put secrets here.
NEXT_PUBLIC_DASHBOARD_APP_LABEL=ORIUS
NEXT_PUBLIC_DASHBOARD_OPERATOR_NAME=Operator
NEXT_PUBLIC_DASHBOARD_OPERATOR_ROLE=Research Operator
